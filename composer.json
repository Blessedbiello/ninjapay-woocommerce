{
  "name": "ninjapay/woocommerce",
  "description": "NinjaPay payment gateway for WooCommerce",
  "type": "wordpress-plugin",
  "license": "GPL-2.0-or-later",
  "homepage": "https://ninjapay.finance",
  "support": {
    "issues": "https://github.com/Blessedbiello/ninjapay-woocommerce/issues",
    "source": "https://github.com/Blessedbiello/ninjapay-woocommerce"
  },
  "require": {
    "php": ">=7.4"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.6",
    "wp-coding-standards/wpcs": "^3.0",
    "squizlabs/php_codesniffer": "^3.10",
    "phpcompatibility/phpcompatibility-wp": "^2.1",
    "yoast/phpunit-polyfills": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "NinjaPay\\WooCommerce\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "NinjaPay\\WooCommerce\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit --testsuite unit",
    "test:integration": "phpunit --testsuite integration",
    "test:all": "phpunit",
    "phpcs": "phpcs --standard=phpcs.xml src/ ninjapay-woocommerce.php",
    "phpcbf": "phpcbf --standard=phpcs.xml src/ ninjapay-woocommerce.php",
    "lint": [
      "@phpcs"
    ],
    "build:zip": "bash bin/build-zip.sh"
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  }
}
